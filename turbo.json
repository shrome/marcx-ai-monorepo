{
  "ui": "tui",
  "globalDependencies": [".env.*"],
  "globalEnv": ["APP_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_*", "DATABASE_URL", "API_URL", "APP_ENV"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env.*"],
      "env": ["NEXT_PUBLIC_*", "DATABASE_URL", "API_URL", "APP_ENV"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "test/**/*.ts"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["e2e/**/*.ts", "playwright.config.ts"]
    }
  }
}
