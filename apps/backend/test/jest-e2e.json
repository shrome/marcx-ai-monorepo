{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "./tsconfig.test.json"
    }]
  },
  "testTimeout": 60000,
  "setupFiles": ["<rootDir>/setup-env.js"],
  "forceExit": true
}
